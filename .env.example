# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=aesthetic

# Cron Jobs (secret to secure cron endpoints)
CRON_SECRET=your-cron-secret

# Google Maps / Places API (New) + Geocoding API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# GitHub Actions Trigger (für ÄsthOp-Scraper aus Admin-UI)
# Token benötigt den Scope "workflow" (GitHub → Settings → Developer Settings → Personal Access Tokens)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=alexandercfriedrich
GITHUB_REPO_NAME=-aesthetic-
